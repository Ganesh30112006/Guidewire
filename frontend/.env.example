# GigGo — Environment Variables
#
# Copy this file to `.env` and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Never commit your real .env file.

# ---------------------------------------------------------------------------
# Backend API (FastAPI)
# ---------------------------------------------------------------------------
# Base URL for backend routes (without trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ---------------------------------------------------------------------------
# Open-Meteo (Tier 2 — Weather Alerts)
# ---------------------------------------------------------------------------
# No API key required for non-commercial usage.
# City used for weather + air-quality lookups (default: Mumbai)
VITE_OPEN_METEO_CITY=Mumbai

# Optional: fixed coordinates to skip geocoding requests.
# Leave empty to auto-resolve from VITE_OPEN_METEO_CITY.
VITE_OPEN_METEO_LATITUDE=
VITE_OPEN_METEO_LONGITUDE=

# ---------------------------------------------------------------------------
# Sentry (Tier 2 — Error Monitoring)
# ---------------------------------------------------------------------------
# 1. Create a project at https://sentry.io
# 2. npm install @sentry/react
# 3. Uncomment the Sentry.init call in src/lib/monitoring.ts
# Without this key errors are only logged to the browser console.
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Supabase (Tier 2 — Real Auth + Database)
# ---------------------------------------------------------------------------
# Get these from your Supabase project settings → API
# 1. npm install @supabase/supabase-js
# 2. Create src/lib/supabase.ts:  createClient(URL, ANON_KEY)
# 3. Replace DEMO_ACCOUNTS in AuthContext with supabase.auth.*
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Razorpay (Tier 2 — Payments)
# ---------------------------------------------------------------------------
# Only the PUBLIC (publishable) key goes here — never put the secret key
# in a VITE_ variable. Handle secrets server-side only.
VITE_RAZORPAY_KEY_ID=
