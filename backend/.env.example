# ── Required ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=giggo
DB_USER=giggo_user
DB_PASSWORD=your_strong_db_password_here
# Optional: use a full DSN instead of DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
# Example: mysql+aiomysql://user:pass@localhost:3306/giggo?charset=utf8mb4
DATABASE_URL_OVERRIDE=

# ── RSA key paths (generate with commands below) ───────────────────────────────
RSA_PRIVATE_KEY_PATH=keys/private.pem
RSA_PUBLIC_KEY_PATH=keys/public.pem

# ── AES-256-GCM field encryption (generate with command below) ─────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
FIELD_ENCRYPTION_KEY=your_64_hex_char_key_here

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=GigGo API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","https://your-frontend-domain.com"]

# ── Token expiry ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate limits ────────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_API=300/minute

# ── Brute force ────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
